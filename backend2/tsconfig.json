{
  // Visit https://aka.ms/tsconfig to read more about this file
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "#DatabaseConnectionModule/*": ["./src/DatabaseRoutes/*"],
      "#Verification/*": ["./src/Auth/*"],
      "#models/*": ["./src/models/*"],
      "#authentication": ["./src/AuthRoutes/*"],
      "#PdfResources/*": ["src/Resources/*"],
      "#JwtPayloadInterface/*": ["./src/types/*"],
      "#adminResources/*": ["./src/Admin_Resources/*"]
    },
    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "nodenext",
    "target": "esnext",
    "types": [],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    // disabling errors showing in compiled js files
    "removeComments": true,
    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmitOnError": true,
    // Style Options
    "noImplicitReturns": false,
    // "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "allowImportingTsExtensions": false,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
}
